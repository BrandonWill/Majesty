////////////////////////////////////////////////////////////////////////////////////////////////////////
function Ratman_Birth	(agent ThisAgent)
// Ratmen commonly call a different birthscript, so this needed to be overridden
// to birth them with Krolm's rage when he's around.
Declare
	list	Lairs;
	integer Random;
	agent AIRootAgent;

Begin

	Random = $RandomNumber (2);

	//Check to see which kind of ratman this is
	If (Random == 0)
		begin
			ThisAgent's "ActiveScript" = $Sleeper_Raider;
			ThisAgent's "BasicScript" = $Sleeper_Raider;
			ThisAgent's "BackScript" = $Sleeper_Raider;
			$DebugOut ("Ratman becomes a SLEEPER_RAIDER!!");
		end
	Else
		begin
			ThisAgent's "ActiveScript" = $Sleeper_Robber;
			ThisAgent's "BasicScript" = $Sleeper_Robber;
			ThisAgent's "BackScript" = $Sleeper_Robber;
			$DebugOut ("Ratman becomes a SLEEPER_ROBBER!!");
		end

	$Sleeper_Birth (ThisAgent);

	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	if ( AIRootAgent's "Quest_Flag_8" == TRUE )
		$Permanent_Monster_Rage ( ThisAgent );

End

////////////////////////////////////////////////////////////////////////////////////////////////////////
function monster_birth ( agent thisagent )
// This is overridden from the base support scripts because in Wrath Of Krolm, we want Rocs/Vargs/Hellbears to be super-tough.
// Player summoned animals are NOT tougher, and enemy animals cannot be charmed.

declare
	agent Parent, AIRootAgent;
	integer gold, player;
	boolean flag;

begin
	AIRootAgent = $RetrieveAgent ( "GPLAIRoot" );

	player = $GetUnitPlayerNumber ( ThisAgent );
	parent = $Parent ( ThisAgent );

	//If Giant Eagle, make them faster and double HP
	If ( ThisAgent's "Title" == "Krolm_Eagle" )
		begin

			//Double the hit points
			$SetAttribute ( ThisAgent, #ATTRIB_MaxHP, $GetAttribute ( ThisAgent, #ATTRIB_MaxHP ) * 2 );
			$SetAttribute ( ThisAgent, #ATTRIB_HP, $GetAttribute ( ThisAgent, #ATTRIB_MaxHP ));

			// Increase Melee
			$SetAttribute ( ThisAgent, #ATTRIB_HtoH, $GetAttribute ( ThisAgent, #ATTRIB_HtoH ) + 30 );

			//Move and attack very quickly
			$adjustattribute ( thisagent, #ATTRIB_MovementRateModifier, -300 );
			$adjustattribute ( thisagent, #ATTRIB_ActionRateModifier, -250 );

			ThisAgent's "Subtype" = "xx"; // This stops Krolm's animals from being charmed.

		end

	//If Red bear, make them stronger with double HP and high MR
	Else if ( ThisAgent's "Title" == "Krolm_Bear" )
		begin

			//Double the hit points
			$SetAttribute ( ThisAgent, #ATTRIB_MaxHP, $GetAttribute ( ThisAgent, #ATTRIB_MaxHP ) * 2 );
			$SetAttribute ( ThisAgent, #ATTRIB_HP, $GetAttribute ( ThisAgent, #ATTRIB_MaxHP ));

			//Double strength
			$SetAttribute ( ThisAgent, #ATTRIB_Strength, $GetAttribute ( ThisAgent, #ATTRIB_Strength ) * 2 );
			$SetAttribute ( ThisAgent, #ATTRIB_HtoH, $GetAttribute ( ThisAgent, #ATTRIB_HtoH ) + 20 );


			//Set MR to 65
			$SetAttribute ( ThisAgent, #ATTRIB_MagicResistance, 65 );

			ThisAgent's "Subtype" = "xx"; // This stops Krolm's animals from being charmed.

		end

	//If White Wolf, then harder to hit and more HP
	Else if ( ThisAgent's "Title" == "Krolm_Wolf" )
		begin

			//Double the hit points
			$SetAttribute ( ThisAgent, #ATTRIB_MaxHP, $GetAttribute ( ThisAgent, #ATTRIB_MaxHP ) * 2 );
			$SetAttribute ( ThisAgent, #ATTRIB_HP, $GetAttribute ( ThisAgent, #ATTRIB_MaxHP ));

			//Increase Dodge and Parry & Melee
			$SetAttribute ( ThisAgent, #ATTRIB_Dodge, $GetAttribute ( ThisAgent, #ATTRIB_Dodge ) + 30 );
			$SetAttribute ( ThisAgent, #ATTRIB_Parry, $GetAttribute ( ThisAgent, #ATTRIB_Parry ) + 30 );
			$SetAttribute ( ThisAgent, #ATTRIB_HtoH, $GetAttribute ( ThisAgent, #ATTRIB_HtoH ) + 30 );

			ThisAgent's "Subtype" = "xx"; // This stops Krolm's animals from being charmed.

		end

	//If parent is Krolm, then this is a temple raider
	If ( $IsValidGamePiece ( Parent ))
		If ( Parent's "Title" == "Krolm" )
			begin

				ThisAgent's "ActiveScript" = $Temple_Raider;
				ThisAgent's "BasicScript" = $Temple_Raider;
				ThisAgent's "BackScript" = $Temple_Raider;
				ThisAgent's "StartingScript" = $Temple_Raider;

			end

	// If krolm is on the map, then the monster is born raged.
	if ( AIRootAgent's "Quest_Flag_8" == TRUE )
		$Permanent_Monster_Rage ( ThisAgent );

	thisagent's "target" = $nullagent ();
	$clearlist ( thisagent's "hostiles" );

	// Call the base script to setup the monster
	$Setup_Quest_Monster ( ThisAgent );

	// this will possibly override a monsters scripts if its artifice has
	// been set by $spawnunit
	$check_override_behavior ( thisagent );

	$NewThread ( thisagent's "activeScript", #Normal_Cycle, thisagent );

	thisagent's "startingScript" = thisagent's "basicScript";
end
